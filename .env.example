# =============================================================================
# Gateway Environment Variables
# =============================================================================
# Copy this file to .env and configure your values

# Upstream API Configuration
UPSTREAM_BASE_URL=https://your-upstream.example
UPSTREAM_API_KEY=replace-with-upstream-api-key
UPSTREAM_MODEL=mimo-v2.5-pro
GATEWAY_UPSTREAM_PROTOCOL=openai_chat
UPSTREAM_MAX_INPUT_TOKENS=1048576
UPSTREAM_MAX_OUTPUT_TOKENS=131072
# Real test upstreams expose chat/responses/messages but usually no direct local-tool runtime endpoints.
# A forced /v1/messages probe can emit Anthropic tool_use; /v1/responses function_call is not proven.
# Keep adapter defaults for reliable Claude Code + Codex local tool execution through Gateway.
GATEWAY_TOOLS_ENABLED=adapter
UPSTREAM_SUPPORTS_TOOLS=0
UPSTREAM_SUPPORTS_FUNCTION_CALLS=0
UPSTREAM_SUPPORTS_PARALLEL_TOOL_CALLS=0

# Gateway Configuration
GATEWAY_PORT=8885
GATEWAY_ADMIN_PASSWORD=your-secure-password
GATEWAY_TOOL_MODE=orchestrate
GATEWAY_MAX_TOOL_ROUNDS=10
GATEWAY_MAX_REQUEST_BODY_BYTES=67108864
GATEWAY_MAX_LOG_PAYLOAD_CHARS=200000

# Context Management
GATEWAY_CONTEXT_ENABLED=1
GATEWAY_CONTEXT_MAX_INPUT_TOKENS=1048576
GATEWAY_CONTEXT_FANOUT_ENABLED=1
GATEWAY_CONTEXT_FANOUT_CHUNK_TOKENS=120000
GATEWAY_CLIENT_CONTEXT_WINDOW=1048576
GATEWAY_CLIENT_AUTO_COMPACT_TOKEN_LIMIT=943718
GATEWAY_CLIENT_OUTPUT_TOKEN_LIMIT=131072
GATEWAY_TEXT_TOOL_ADAPTER_COMPACT_TOKEN_LIMIT=48000

# Tool Configuration
# Safe defaults for production. Set to 1 only for trusted local coding-agent use.
GATEWAY_EXPOSE_BUILTIN_TOOLS=1
GATEWAY_ALLOW_WRITE_TOOLS=0
GATEWAY_ALLOW_SHELL_TOOLS=0
GATEWAY_EXECUTE_USER_SIDE_TOOLS=0
# Cloud default: generic WebFetch/WebSearch cannot access Gateway service
# private/localhost networks. Set to 1 only for admin-approved service-side
# network tools.
GATEWAY_ALLOW_PRIVATE_NETWORK_TOOLS=0
GATEWAY_IMAGE_MAX_DIMENSION=2048

# Streaming
GATEWAY_UPSTREAM_STREAM_AGGREGATE=1

# Memory
GATEWAY_MEMORY_ENABLED=1

# Workspace
# Cloud mode: leave empty. Downstream clients must provide their own workspace
# metadata; the Gateway service must not treat its local filesystem as the
# user's Codex/Claude Code workspace.
GATEWAY_WORKSPACE_ROOT=

# Security (for production)
GATEWAY_DOWNSTREAM_KEY=your-gateway-api-key

# Long Context Model (optional)
# GATEWAY_LONG_CONTEXT_BASE_URL=https://api.openai.com
# GATEWAY_LONG_CONTEXT_API_KEY=replace-with-long-context-api-key
# GATEWAY_LONG_CONTEXT_MODEL=gpt-4-1106-preview
# GATEWAY_LONG_CONTEXT_PROTOCOL=openai_chat
