# =============================================================================
# Gateway Environment Variables
# =============================================================================
# Copy this file to .env and configure your values

# Upstream API Configuration
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=sk-your-api-key
UPSTREAM_MODEL=gpt-4o
GATEWAY_UPSTREAM_PROTOCOL=openai_chat

# Gateway Configuration
GATEWAY_PORT=8885
GATEWAY_ADMIN_PASSWORD=your-secure-password
GATEWAY_TOOL_MODE=orchestrate
GATEWAY_MAX_TOOL_ROUNDS=10
GATEWAY_MAX_REQUEST_BODY_BYTES=67108864

# Context Management
GATEWAY_CONTEXT_ENABLED=1
GATEWAY_CONTEXT_MAX_INPUT_TOKENS=24000
GATEWAY_CONTEXT_FANOUT_ENABLED=1

# Tool Configuration
# Safe defaults for production. Set to 1 only for trusted local coding-agent use.
GATEWAY_EXPOSE_BUILTIN_TOOLS=1
GATEWAY_ALLOW_WRITE_TOOLS=0
GATEWAY_ALLOW_SHELL_TOOLS=0

# Streaming
GATEWAY_UPSTREAM_STREAM_AGGREGATE=1

# Memory
GATEWAY_MEMORY_ENABLED=1

# Workspace
GATEWAY_WORKSPACE_ROOT=./workspace

# Security (for production)
GATEWAY_DOWNSTREAM_KEY=your-gateway-api-key

# Long Context Model (optional)
# GATEWAY_LONG_CONTEXT_BASE_URL=https://api.openai.com
# GATEWAY_LONG_CONTEXT_API_KEY=replace-with-long-context-api-key
# GATEWAY_LONG_CONTEXT_MODEL=gpt-4-1106-preview
# GATEWAY_LONG_CONTEXT_PROTOCOL=openai_chat
