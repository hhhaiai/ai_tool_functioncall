# =============================================================================
# Gateway Environment Variables
# =============================================================================
# Copy this file to .env and configure your values

# Upstream API Configuration
UPSTREAM_BASE_URL=https://your-upstream.example
UPSTREAM_API_KEY=replace-with-upstream-api-key
UPSTREAM_MODEL=mimo-v2.5-pro
GATEWAY_UPSTREAM_PROTOCOL=openai_chat
UPSTREAM_RETRY_MAX_ATTEMPTS=3
UPSTREAM_RETRY_INITIAL_DELAY=0.5
UPSTREAM_RETRY_MAX_DELAY=4.0
UPSTREAM_RETRY_MAX_ELAPSED=90.0
UPSTREAM_MAX_INPUT_TOKENS=1048576
UPSTREAM_MAX_OUTPUT_TOKENS=131072
UPSTREAM_MAX_RESPONSE_BYTES=33554432
UPSTREAM_MAX_STDERR_BYTES=262144
UPSTREAM_MAX_STREAM_EVENT_BYTES=1048576
UPSTREAM_MAX_STREAM_EVENTS=100000
# Real test upstreams expose chat/responses/messages but usually no direct local-tool runtime endpoints.
# A forced /v1/messages probe can emit Anthropic tool_use; /v1/responses function_call is not proven.
# Keep adapter defaults for reliable Claude Code + Codex local tool execution through Gateway.
GATEWAY_TOOLS_ENABLED=adapter
UPSTREAM_SUPPORTS_TOOLS=0
UPSTREAM_SUPPORTS_FUNCTION_CALLS=0
UPSTREAM_SUPPORTS_PARALLEL_TOOL_CALLS=0

# Gateway Configuration
GATEWAY_PORT=8885
GATEWAY_HOST=127.0.0.1
# auto: non-loopback listeners require strong credentials; private is only for
# a listener protected by loopback publication/firewall/private ingress.
GATEWAY_PUBLIC_EXPOSURE=auto
GATEWAY_ADMIN_PASSWORD=your-secure-password
GATEWAY_TOOL_MODE=orchestrate
GATEWAY_MAX_TOOL_ROUNDS=10
GATEWAY_MAX_CONCURRENT_REQUESTS=32
GATEWAY_CONCURRENCY_BACKEND=sqlite
GATEWAY_CONCURRENCY_DB_PATH=.gateway_runtime/admission.sqlite3
GATEWAY_CONCURRENCY_FALLBACK_BACKEND=none
GATEWAY_CONCURRENCY_BUSY_TIMEOUT_MS=1000
GATEWAY_CONCURRENCY_LEASE_TTL_SECONDS=120
GATEWAY_CONCURRENCY_HEARTBEAT_SECONDS=30
GATEWAY_CONCURRENCY_QUEUE_TIMEOUT=5
GATEWAY_AGENT_PLANNER_STRICT_EVERY_TURN=1
GATEWAY_MAX_REQUEST_BODY_BYTES=67108864
GATEWAY_CORS_ENABLED=0
# Comma-separated exact origins, for example: https://console.example.com
GATEWAY_CORS_ALLOWED_ORIGINS=
GATEWAY_MAX_LOG_PAYLOAD_CHARS=200000
GATEWAY_RATE_LIMIT_ENABLED=1
GATEWAY_RATE_LIMIT_RPM=120
GATEWAY_RATE_LIMIT_BACKEND=sqlite
GATEWAY_RATE_LIMIT_DB_PATH=.gateway_runtime/rate_limits.sqlite3
GATEWAY_RATE_LIMIT_FALLBACK_BACKEND=memory
GATEWAY_RATE_LIMIT_BUSY_TIMEOUT_MS=1000
GATEWAY_RATE_LIMIT_STATE_TTL_SECONDS=3600
GATEWAY_MCP_MAX_HEADER_BYTES=65536
GATEWAY_MCP_MAX_MESSAGE_BYTES=16777216
GATEWAY_MCP_MAX_STDERR_BYTES=262144

# Bounded persistent-data maintenance. Runtime artifact deletion is opt-in and
# starts in dry-run mode; primary SQLite row retention is active by default.
GATEWAY_MAINTENANCE_ENABLED=1
GATEWAY_MAINTENANCE_INTERVAL_SECONDS=300
GATEWAY_MAINTENANCE_DRY_RUN=0
GATEWAY_MAINTENANCE_BATCH_SIZE=1000
GATEWAY_MAINTENANCE_MAX_BATCHES=4
GATEWAY_MAINTENANCE_VACUUM_PAGES=256
GATEWAY_REQUEST_LOG_RETENTION_DAYS=30
GATEWAY_REQUEST_LOG_MAX_ROWS=100000
GATEWAY_TOOL_FAILURE_RETENTION_DAYS=90
GATEWAY_TOOL_FAILURE_MAX_ROWS=50000
GATEWAY_MEMORY_RETENTION_DAYS=90
GATEWAY_MEMORY_MAX_ROWS=50000
GATEWAY_PLANNER_RETENTION_DAYS=30
GATEWAY_PLANNER_MAX_ROWS=20000
GATEWAY_PLANNER_EVENT_MAX_ROWS=100000
GATEWAY_RUNTIME_CLEANUP_ENABLED=0
GATEWAY_RUNTIME_CLEANUP_DRY_RUN=1
GATEWAY_RUNTIME_RETENTION_DAYS=7
GATEWAY_RUNTIME_MAX_ENTRIES_PER_RUN=20
GATEWAY_RUNTIME_MAX_ENTRY_BYTES=268435456

# Context Management
GATEWAY_CONTEXT_ENABLED=1
GATEWAY_CONTEXT_MAX_INPUT_TOKENS=1048576
GATEWAY_CONTEXT_FANOUT_ENABLED=1
GATEWAY_CONTEXT_FANOUT_CHUNK_TOKENS=120000
GATEWAY_CLIENT_CONTEXT_WINDOW=1048576
GATEWAY_CLIENT_AUTO_COMPACT_TOKEN_LIMIT=943718
GATEWAY_CLIENT_OUTPUT_TOKEN_LIMIT=131072
GATEWAY_TEXT_TOOL_ADAPTER_COMPACT_TOKEN_LIMIT=48000

# Tool Configuration
# Safe defaults for production. Set to 1 only for trusted local coding-agent use.
GATEWAY_EXPOSE_BUILTIN_TOOLS=1
GATEWAY_ALLOW_WRITE_TOOLS=0
GATEWAY_ALLOW_SHELL_TOOLS=0
GATEWAY_EXECUTE_USER_SIDE_TOOLS=0
# Extra variable names that tool subprocesses may inherit. Keep empty unless a
# trusted executable has a documented requirement; secrets are excluded by default.
GATEWAY_TOOL_ENV_ALLOWLIST=
# auto selects macOS sandbox-exec or Linux Landlock without adding container
# capabilities. rlimit keeps only the worker/resource boundary.
GATEWAY_SANDBOX_ISOLATION_BACKEND=auto
# Blank selects system_and_workspace for OS backends and inherited for rlimit.
GATEWAY_SANDBOX_READ_POLICY=
# Extra absolute paths hidden from sandboxed tools (comma-separated).
GATEWAY_SANDBOX_DENY_READ_PATHS=
# Optional parent containing one top-level directory per tenant/workspace.
GATEWAY_SANDBOX_TENANT_ROOT=
# inherited preserves tool networking; deny blocks network for jobs using it.
GATEWAY_SANDBOX_NETWORK_POLICY=inherited
# Per-job worker limits. Blank CPU uses wall-timeout+1 for short commands and
# no cumulative CPU default for long-lived exec/MCP. Memory/PID are opt-in.
GATEWAY_SANDBOX_CPU_SECONDS=
GATEWAY_SANDBOX_MEMORY_BYTES=
GATEWAY_SANDBOX_MAX_PROCESSES=
GATEWAY_SANDBOX_MAX_OPEN_FILES=256
GATEWAY_SANDBOX_MAX_FILE_BYTES=67108864
# Local Read/Grep results stay memory-only unless explicitly opted in.
GATEWAY_TOOL_CACHE_PERSIST_LOCAL_RESULTS=0
# Cloud default: generic WebFetch/WebSearch cannot access Gateway service
# private/localhost networks. Set to 1 only for admin-approved service-side
# network tools.
GATEWAY_ALLOW_PRIVATE_NETWORK_TOOLS=0
GATEWAY_IMAGE_MAX_DIMENSION=2048

# Streaming
GATEWAY_UPSTREAM_STREAM_AGGREGATE=1

# Memory
GATEWAY_MEMORY_ENABLED=1

# Workspace
# Cloud mode: leave empty. Downstream clients must provide their own workspace
# metadata; the Gateway service must not treat its local filesystem as the
# user's Codex/Claude Code workspace.
GATEWAY_WORKSPACE_ROOT=

# Security (for production)
GATEWAY_DOWNSTREAM_KEY=your-gateway-api-key

# Long Context Model (optional)
# GATEWAY_LONG_CONTEXT_BASE_URL=https://api.openai.com
# GATEWAY_LONG_CONTEXT_API_KEY=replace-with-long-context-api-key
# GATEWAY_LONG_CONTEXT_MODEL=gpt-4-1106-preview
# GATEWAY_LONG_CONTEXT_PROTOCOL=openai_chat
# Optional service-wide Admin Skill catalog. Defaults to <Gateway cwd>/skills.
GATEWAY_ADMIN_SKILLS_ROOT=
